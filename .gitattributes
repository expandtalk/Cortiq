# Auto detect text files and perform LF normalization
* text=auto

# JavaScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# Markdown
*.md text eol=lf

# SQL
*.sql text eol=lf

# Shell scripts
*.sh text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
