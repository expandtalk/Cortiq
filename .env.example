# CortIQ — Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to git

# ── Supabase (required) ──────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"        # safe to expose in browser

# ── Google OAuth (optional — required for Search Console integration) ────────
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://YOUR_PROJECT_ID.supabase.co/functions/v1/gsc-oauth-callback
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ── CortIQ marketing-site self-tracking (optional) ───────────────────────────
# Injected into index.html at build time (Vite %VITE_*% substitution). Use a
# freshly-rotated, ingest-only key — never hardcode credentials in index.html.
# TRACK_URL is the Edge Functions BASE (no /track-event suffix) — spa-tracking.js
# appends /track-event, /record-conversion, etc. itself.
VITE_CORTIQ_TRACK_URL="https://your-project-id.supabase.co/functions/v1"
VITE_CORTIQ_COMPANY_ID="your-company-id"
VITE_CORTIQ_API_KEY="your-rotated-ingest-key"
