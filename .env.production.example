# =============================================================================
# CortIQ Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in your actual production values
# IMPORTANT: Never commit .env.production to version control!
# =============================================================================

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =============================================================================

# Supabase Project Configuration
VITE_SUPABASE_URL=https://cxmkdtgfocgbfizawlwa.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key_here
VITE_SUPABASE_PROJECT_ID=cxmkdtgfocgbfizawlwa

# Service Role Key (Only for server-side operations, NOT exposed to frontend)
# WARNING: Keep this secret! Do not include in frontend build
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment
VITE_APP_ENV=production
NODE_ENV=production

# Application URLs
VITE_APP_URL=https://cortiq.se
VITE_API_URL=https://cortiq.se/api
VITE_TRACKING_URL=https://cortiq.se

# Application Settings
VITE_APP_NAME=CortIQ
VITE_APP_TAGLINE="Agentic Browser Analytics"
VITE_APP_VERSION=1.0.0

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Core Features
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_AI_TRACKING=true
VITE_ENABLE_HEATMAPS=true
VITE_ENABLE_SESSION_RECORDING=true
VITE_ENABLE_FORM_ANALYTICS=true
VITE_ENABLE_AB_TESTING=true

# Advanced Features
VITE_ENABLE_GEOLOCATION=true
VITE_ENABLE_MEDIA_ANALYTICS=true
VITE_ENABLE_TAG_MANAGER=true
VITE_ENABLE_DATA_WAREHOUSE=true
VITE_ENABLE_WHITE_LABEL=true
VITE_ENABLE_COHORT_ANALYSIS=true
VITE_ENABLE_SEO_VITALS=true
VITE_ENABLE_SAML_SSO=true

# Integrations
VITE_ENABLE_GA4_INTEGRATION=true
VITE_ENABLE_GSC_INTEGRATION=true
VITE_ENABLE_WORDPRESS_PLUGIN=true
VITE_ENABLE_SERVER_LOG_IMPORT=true

# Beta Features (Set to false for production)
VITE_ENABLE_EXPERIMENTAL_FEATURES=false
VITE_ENABLE_DEBUG_MODE=false

# =============================================================================
# TRACKING CONFIGURATION
# =============================================================================

# Tracking Settings
VITE_TRACKING_ENABLED=true
VITE_TRACKING_DEBUG=false
VITE_COOKIE_FREE_MODE=true
VITE_GDPR_COMPLIANT=true
VITE_IP_ANONYMIZATION=true

# Event Tracking
VITE_TRACK_PAGE_VIEWS=true
VITE_TRACK_CLICKS=true
VITE_TRACK_SCROLL=true
VITE_TRACK_FORMS=true
VITE_TRACK_MEDIA=true
VITE_TRACK_ERRORS=true

# AI Agent Detection
VITE_AI_AGENT_DETECTION=true
VITE_AI_AGENT_TRACKING=true
VITE_TRACK_CHATGPT=true
VITE_TRACK_PERPLEXITY=true
VITE_TRACK_CLAUDE=true
VITE_TRACK_GEMINI=true

# =============================================================================
# RATE LIMITING & PERFORMANCE
# =============================================================================

# Rate Limits (events per time window)
VITE_RATE_LIMIT_EVENTS=10000
VITE_RATE_LIMIT_WINDOW=3600000
VITE_RATE_LIMIT_ANALYTICS=1000
VITE_RATE_LIMIT_API=5000

# Performance Settings
VITE_API_TIMEOUT=30000
VITE_REQUEST_DEBOUNCE=300
VITE_BATCH_SIZE=100
VITE_BATCH_INTERVAL=5000

# Cache Settings
VITE_CACHE_ENABLED=true
VITE_CACHE_TTL=300000
VITE_CACHE_MAX_SIZE=100

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS Settings
VITE_CORS_ORIGINS=https://cortiq.se,https://www.cortiq.se
VITE_CORS_CREDENTIALS=true

# Security Headers
VITE_CSP_ENABLED=true
VITE_HSTS_ENABLED=true
VITE_X_FRAME_OPTIONS=SAMEORIGIN
VITE_X_CONTENT_TYPE_OPTIONS=nosniff

# Authentication
VITE_AUTH_SESSION_TIMEOUT=86400000
VITE_AUTH_REFRESH_INTERVAL=3600000
VITE_AUTH_PASSWORD_MIN_LENGTH=8
VITE_AUTH_REQUIRE_EMAIL_VERIFICATION=true

# Encryption
VITE_ENCRYPTION_ENABLED=true
VITE_HASH_ALGORITHM=sha256

# =============================================================================
# GDPR & PRIVACY
# =============================================================================

# GDPR Compliance
VITE_GDPR_MODE=true
VITE_COOKIE_CONSENT_REQUIRED=false
VITE_DATA_RETENTION_DAYS=730
VITE_ANONYMIZE_IP=true
VITE_ANONYMIZE_USER_AGENT=false
VITE_RESPECT_DNT=true

# Privacy Settings
VITE_COLLECT_PERSONAL_DATA=false
VITE_COLLECT_GEOLOCATION=true
VITE_COLLECT_DEVICE_INFO=true
VITE_COLLECT_SESSION_RECORDINGS=true

# =============================================================================
# ANALYTICS & REPORTING
# =============================================================================

# Analytics Configuration
VITE_ANALYTICS_SAMPLE_RATE=1.0
VITE_HEATMAP_SAMPLE_RATE=0.1
VITE_SESSION_RECORDING_SAMPLE_RATE=0.05
VITE_REAL_TIME_UPDATES=true

# Data Aggregation
VITE_AGGREGATE_INTERVAL=3600000
VITE_AGGREGATE_RETENTION=365
VITE_RAW_DATA_RETENTION=90

# Reporting
VITE_REPORTS_ENABLED=true
VITE_SCHEDULED_REPORTS=true
VITE_EXPORT_PDF=true
VITE_EXPORT_CSV=true
VITE_EXPORT_JSON=true

# =============================================================================
# INTEGRATIONS - GOOGLE ANALYTICS 4
# =============================================================================

# GA4 Settings (Optional - leave empty if not using)
VITE_GA4_MEASUREMENT_ID=
VITE_GA4_API_SECRET=
VITE_GA4_PROPERTY_ID=
VITE_GA4_SYNC_ENABLED=false
VITE_GA4_SYNC_INTERVAL=86400000

# =============================================================================
# INTEGRATIONS - GOOGLE SEARCH CONSOLE
# =============================================================================

# GSC Settings (Optional - leave empty if not using)
VITE_GSC_PROPERTY_URL=
VITE_GSC_CLIENT_ID=
VITE_GSC_CLIENT_SECRET=
VITE_GSC_SYNC_ENABLED=false

# =============================================================================
# INTEGRATIONS - DATA WAREHOUSE
# =============================================================================

# Warehouse Settings (Optional)
VITE_WAREHOUSE_ENABLED=false
VITE_WAREHOUSE_TYPE=
VITE_WAREHOUSE_HOST=
VITE_WAREHOUSE_PORT=
VITE_WAREHOUSE_DATABASE=
VITE_WAREHOUSE_SYNC_INTERVAL=86400000

# BigQuery (if using)
VITE_BIGQUERY_PROJECT_ID=
VITE_BIGQUERY_DATASET=
VITE_BIGQUERY_CREDENTIALS=

# Snowflake (if using)
VITE_SNOWFLAKE_ACCOUNT=
VITE_SNOWFLAKE_USERNAME=
VITE_SNOWFLAKE_PASSWORD=
VITE_SNOWFLAKE_WAREHOUSE=
VITE_SNOWFLAKE_DATABASE=
VITE_SNOWFLAKE_SCHEMA=

# =============================================================================
# WHITE LABEL CONFIGURATION
# =============================================================================

# White Label Settings (Enterprise feature)
VITE_WHITE_LABEL_ENABLED=false
VITE_WHITE_LABEL_NAME=CortIQ
VITE_WHITE_LABEL_LOGO=
VITE_WHITE_LABEL_FAVICON=
VITE_WHITE_LABEL_PRIMARY_COLOR=#6366f1
VITE_WHITE_LABEL_SECONDARY_COLOR=#8b5cf6
VITE_WHITE_LABEL_DOMAIN=

# =============================================================================
# SAML SSO CONFIGURATION
# =============================================================================

# SAML Settings (Enterprise feature)
VITE_SAML_ENABLED=false
VITE_SAML_ENTITY_ID=
VITE_SAML_SSO_URL=
VITE_SAML_CERTIFICATE=
VITE_SAML_SIGN_REQUESTS=true
VITE_SAML_WANT_ASSERTIONS_SIGNED=true

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email Settings (For notifications and reports)
VITE_EMAIL_ENABLED=true
VITE_EMAIL_FROM=noreply@cortiq.se
VITE_EMAIL_REPLY_TO=support@cortiq.se
VITE_EMAIL_PROVIDER=supabase

# SMTP Settings (if not using Supabase email)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Monitoring
VITE_MONITORING_ENABLED=true
VITE_ERROR_TRACKING_ENABLED=true
VITE_PERFORMANCE_MONITORING=true

# Sentry (Optional)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
VITE_LOG_LEVEL=info
VITE_LOG_TO_CONSOLE=false
VITE_LOG_TO_FILE=true
VITE_LOG_FILE_PATH=/var/log/cortiq/app.log

# =============================================================================
# CDN & ASSETS
# =============================================================================

# CDN Configuration (Optional)
VITE_CDN_ENABLED=false
VITE_CDN_URL=
VITE_ASSETS_URL=https://cortiq.se

# Static Assets
VITE_STATIC_PATH=/assets
VITE_UPLOAD_PATH=/uploads
VITE_MAX_UPLOAD_SIZE=10485760

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Connection Pooling
VITE_DB_POOL_MIN=2
VITE_DB_POOL_MAX=10
VITE_DB_CONNECTION_TIMEOUT=30000
VITE_DB_IDLE_TIMEOUT=600000

# Query Performance
VITE_DB_SLOW_QUERY_THRESHOLD=1000
VITE_DB_QUERY_TIMEOUT=30000
VITE_DB_MAX_QUERY_SIZE=1048576

# =============================================================================
# WORDPRESS PLUGIN CONFIGURATION
# =============================================================================

# WordPress Plugin Settings
VITE_WP_PLUGIN_ENABLED=true
VITE_WP_PLUGIN_VERSION=1.0.0
VITE_WP_PLUGIN_DOWNLOAD_URL=https://cortiq.se/downloads/cortiq-wordpress-plugin.zip
VITE_WP_API_ENDPOINT=https://cortiq.se/wp-api

# =============================================================================
# A/B TESTING CONFIGURATION
# =============================================================================

# A/B Testing Settings
VITE_AB_TESTING_ENABLED=true
VITE_AB_TESTING_MIN_SAMPLE_SIZE=100
VITE_AB_TESTING_CONFIDENCE_LEVEL=0.95
VITE_AB_TESTING_AUTO_WINNER=false

# =============================================================================
# HEATMAP CONFIGURATION
# =============================================================================

# Heatmap Settings
VITE_HEATMAP_ENABLED=true
VITE_HEATMAP_MAX_POINTS=10000
VITE_HEATMAP_BLUR_RADIUS=25
VITE_HEATMAP_MAX_OPACITY=0.8
VITE_HEATMAP_GRADIENT_START=#0000ff
VITE_HEATMAP_GRADIENT_MIDDLE=#00ff00
VITE_HEATMAP_GRADIENT_END=#ff0000

# =============================================================================
# SESSION RECORDING CONFIGURATION
# =============================================================================

# Session Recording Settings
VITE_SESSION_RECORDING_ENABLED=true
VITE_SESSION_RECORDING_MAX_DURATION=600000
VITE_SESSION_RECORDING_BLOCK_SENSITIVE=true
VITE_SESSION_RECORDING_MASK_TEXT=true
VITE_SESSION_RECORDING_IGNORE_CLASS=sensitive

# =============================================================================
# NOTIFICATIONS & ALERTS
# =============================================================================

# Notification Settings
VITE_NOTIFICATIONS_ENABLED=true
VITE_NOTIFICATIONS_EMAIL=true
VITE_NOTIFICATIONS_SLACK=false
VITE_NOTIFICATIONS_WEBHOOK=

# Alert Thresholds
VITE_ALERT_HIGH_ERROR_RATE=0.05
VITE_ALERT_HIGH_LATENCY=5000
VITE_ALERT_LOW_CONVERSION=0.01
VITE_ALERT_TRAFFIC_SPIKE=2.0

# =============================================================================
# MAINTENANCE & BACKUPS
# =============================================================================

# Maintenance Mode
VITE_MAINTENANCE_MODE=false
VITE_MAINTENANCE_MESSAGE="CortIQ is currently undergoing maintenance. We'll be back soon!"

# Backup Settings
VITE_BACKUP_ENABLED=true
VITE_BACKUP_INTERVAL=86400000
VITE_BACKUP_RETENTION_DAYS=30
VITE_BACKUP_DESTINATION=s3

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Build Configuration
VITE_BUILD_SOURCEMAP=false
VITE_BUILD_MINIFY=true
VITE_BUILD_TARGET=es2015

# Runtime Configuration
VITE_LAZY_LOAD_COMPONENTS=true
VITE_PREFETCH_ENABLED=true
VITE_SERVICE_WORKER_ENABLED=false

# Developer Tools
VITE_DEV_TOOLS_ENABLED=false
VITE_REACT_PROFILER=false
VITE_NETWORK_INSPECTOR=false

# =============================================================================
# LEGAL & COMPLIANCE
# =============================================================================

# Legal
VITE_PRIVACY_POLICY_URL=https://cortiq.se/privacy
VITE_TERMS_OF_SERVICE_URL=https://cortiq.se/terms
VITE_COOKIE_POLICY_URL=https://cortiq.se/cookies
VITE_CONTACT_EMAIL=support@cortiq.se

# Compliance
VITE_GDPR_COMPLIANT=true
VITE_CCPA_COMPLIANT=true
VITE_SOC2_COMPLIANT=false
VITE_HIPAA_COMPLIANT=false

# =============================================================================
# END OF CONFIGURATION
# =============================================================================

# IMPORTANT NOTES:
# 1. Keep your production .env file secure - never commit it to version control
# 2. Use strong, unique keys for SUPABASE_SERVICE_ROLE_KEY
# 3. Regularly rotate API keys and secrets
# 4. Review and adjust rate limits based on your traffic
# 5. Enable only the features you need to reduce attack surface
# 6. Monitor logs for unusual activity
# 7. Keep this file updated as new environment variables are added

# For more information, see:
# - Deployment documentation: DEPLOYMENT.md
# - Security guidelines: security-guidelines.md
# - Supabase documentation: https://supabase.com/docs
